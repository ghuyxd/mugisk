## pnpm configuration for the Mugisk monorepo

# Allow build scripts for native modules and tools that require them.
# These are audited, known-safe packages:
#   - @prisma/client, @prisma/engines, prisma: Prisma ORM binary downloads
#   - electron: Electron binary download
#   - esbuild: esbuild binary (used by Vite and tsup)
#   - sharp: image processing (used by Next.js for image optimization)
#   - unrs-resolver: used by eslint-plugin-import

allowed-build-scripts=@prisma/client,@prisma/engines,prisma,electron,esbuild,sharp,unrs-resolver
