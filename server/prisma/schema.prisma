// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

enum ScanType {
  WATCH
  MANUAL_RESCAN
}

enum ScanStatus {
  SUCCESS
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

/// A registered account. Admins can manage the library; Users can stream.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isDisabled   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions    Session[]
  playlists   Playlist[]
  playHistory PlayHistory[]

  @@index([email])
  @@map("users")
}

/// A refresh-token-backed device session for a User.
model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// A music artist (may have many albums and tracks).
model Artist {
  id       String  @id @default(cuid())
  name     String
  bio      String?
  imageUrl String?

  albums Album[]
  tracks Track[]

  @@map("artists")
}

/// A release album belonging to an Artist.
model Album {
  id       String  @id @default(cuid())
  title    String
  artistId String
  year     Int?
  coverUrl String?

  artist Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@index([artistId])
  @@map("albums")
}

/// A single audio track on disk. filePath and fileHash are unique identifiers
/// used by the scanner to detect duplicates and moved files.
model Track {
  id              String   @id @default(cuid())
  title           String
  albumId         String?
  artistId        String
  trackNumber     Int?
  discNumber      Int?
  durationSeconds Int
  genre           String?
  filePath        String   @unique
  fileHash        String   @unique
  format          String
  bitrate         Int?
  /// AI-generated tags stored as a JSON array of strings.
  aiTags          String[]
  createdAt       DateTime @default(now())

  album          Album?          @relation(fields: [albumId], references: [id], onDelete: SetNull)
  artist         Artist          @relation(fields: [artistId], references: [id], onDelete: Restrict)
  playlistTracks PlaylistTrack[]
  playHistory    PlayHistory[]

  @@index([artistId])
  @@index([albumId])
  @@index([filePath])
  @@index([fileHash])
  @@map("tracks")
}

/// A user-curated playlist.
model Playlist {
  id        String   @id @default(cuid())
  name      String
  userId    String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([userId])
  @@map("playlists")
}

/// Join table between Playlist and Track, with an explicit ordering position.
model PlaylistTrack {
  id         String @id @default(cuid())
  playlistId String
  trackId    String
  position   Int

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId])
  @@map("playlist_tracks")
}

/// Records every time a User plays a Track (scrobble log).
model PlayHistory {
  id       String   @id @default(cuid())
  userId   String
  trackId  String
  playedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trackId])
  @@map("play_history")
}

/// Audit log for library scan jobs (both filesystem watch events and manual rescans).
model ScanLog {
  id        String     @id @default(cuid())
  type      ScanType
  status    ScanStatus
  /// The file that triggered this log entry (null for batch/summary entries).
  filePath  String?
  message   String?
  createdAt DateTime   @default(now())

  @@index([createdAt])
  @@index([filePath])
  @@map("scan_logs")
}
