# ─────────────────────────────────────────────────────────────────────────────
# Mugisk Environment Variables — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string (used by Prisma and the server)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://mugisk:mugisk_dev@localhost:5432/mugisk"

# Password for the postgres Docker service (matches DATABASE_URL above)
POSTGRES_PASSWORD="mugisk_dev"

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_me_generate_a_random_64_byte_hex_string"
JWT_REFRESH_SECRET="change_me_generate_a_different_random_64_byte_hex_string"

# Access token TTL (e.g. "15m", "1h")
JWT_ACCESS_TOKEN_TTL="15m"
# Refresh token TTL (e.g. "7d", "30d")
JWT_REFRESH_TOKEN_TTL="7d"

# ── Music Library ─────────────────────────────────────────────────────────────
# Absolute path to the directory containing your music files.
# The server uses chokidar to watch for changes.
MUSIC_LIBRARY_PATH="/path/to/your/music"

# ── AI Integration (optional — Phase N) ──────────────────────────────────────
# Set either ANTHROPIC_API_KEY or OPENAI_API_KEY depending on which provider
# you configure in the AI integration phase.
AI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"

# ── Admin Seed User ───────────────────────────────────────────────────────────
# Used by `pnpm db:seed` (prisma/seed.ts) to create the initial admin account.
# Change ADMIN_PASSWORD before running in production.
ADMIN_EMAIL="admin@mugisk.local"
ADMIN_PASSWORD="changeme123"
